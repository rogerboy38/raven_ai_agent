+# --- Ingestion-schema mapping -------------------------------------------------
+# The skill speaks in logical sensor types (temperature/humidity/soil/...), but
+# readings are stored in the `IoT Sensor Reading` DocType by the RPi ingestion
+# (sensor_reader_dual.py) keyed on `device_name` with a typed value column —
+# NOT bot_id/value/gpio_pin. This maps each logical type to the stored
+# sensor_type value(s) and the column its value actually lives in.
+STORED_SCHEMA = {
+    "temperature": {"sensor_types": ["Ford Temperature", "DHT11"], "value_field": "temperature"},
+    "humidity":    {"sensor_types": ["DHT11"],                      "value_field": "humidity"},
+    "soil":        {"sensor_types": ["Soil Moisture"],             "value_field": "soil_moisture"},
