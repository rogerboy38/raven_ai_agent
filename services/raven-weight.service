[Unit]
Description=Raven Weight Capture — Flask Web App (bot-iot-l01)
Documentation=https://bot1.sysmayal.ngrok.io
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=admin
Group=admin
WorkingDirectory=/home/admin/raven-bot
EnvironmentFile=/home/admin/raven-bot/rpi_client/.env
Environment=PYTHONUNBUFFERED=1
Environment=SCALE_BACKEND=sensor_skill
Environment=SENSOR_SKILL_ID=scale_plant
ExecStart=/home/admin/raven-bot/raven-env/bin/python3 /home/admin/raven-bot/rpi_client/web_app.py
Restart=always
RestartSec=5
WatchdogSec=120

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/admin/raven-bot/rpi_client
ProtectHome=false

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=raven-weight

[Install]
WantedBy=multi-user.target
