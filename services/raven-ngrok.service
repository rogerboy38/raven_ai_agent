[Unit]
Description=Raven ngrok Tunnel — bot1.sysmayal.ngrok.io → :5000
After=network-online.target raven-weight.service
Wants=network-online.target
Requires=raven-weight.service
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=admin
Group=admin
WorkingDirectory=/home/admin/raven-bot
ExecStartPre=/bin/bash -c 'until curl -sf http://localhost:5000/api/status >/dev/null 2>&1; do echo "Waiting for Flask..."; sleep 2; done'
ExecStart=/usr/local/bin/ngrok http --url=bot1.sysmayal.ngrok.io 5000
Restart=always
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=raven-ngrok

[Install]
WantedBy=multi-user.target
